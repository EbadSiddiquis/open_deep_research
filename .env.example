# Claude-native deep research workspace -- environment template.
#
# Copy to .env:  cp .env.example .env
#
# IMPORTANT: This workflow uses the Claude account you are signed into in Claude
# Code. It does NOT call any hosted model API from Python. Do not set
# ANTHROPIC_API_KEY (or any other model-provider key) if you want Claude Code to
# use your Claude subscription -- setting one can cause separate API billing.

# Optional. Required ONLY for Tavily-backed web search. Leave blank to run
# without live search (the MCP server still starts; non-search tools still work;
# Claude can use its client's native web search or your provided URLs/documents).
TAVILY_API_KEY=

# Optional Tavily tuning.
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=advanced

# Optional additional retrieval backends (all optional; Claude still reasons).
# Enable any subset. These are RETRIEVAL ONLY -- not model-provider keys.
#   EXA_API_KEY        -> semantic/neural web search (exa_search tool). Get at exa.ai.
#   FIRECRAWL_API_KEY  -> best deep extractor (firecrawl_extract). Get at firecrawl.dev.
#   JINA_API_KEY       -> raises Jina Reader limits (jina_extract works WITHOUT a key too).
EXA_API_KEY=
FIRECRAWL_API_KEY=
JINA_API_KEY=

# Where research runs are stored (gitignored). Default: .research_runs
RESEARCH_RUNS_DIR=.research_runs
